# WAYPOINT — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to git.

# Required — get from https://aistudio.google.com/apikey
# Covers: Gemini (agent + voice), Google Search grounding, Google Vision API
GOOGLE_API_KEY=your_google_api_key_here

# Use Google AI Studio (free tier). Set TRUE if using Vertex AI instead.
GOOGLE_GENAI_USE_VERTEXAI=FALSE

# Optional — only needed if you want real walking distances from Google Maps.
# Without it, the app uses a haversine estimate (still accurate enough).
# Get from: https://console.cloud.google.com → Maps Distance Matrix API
# GOOGLE_MAPS_API_KEY=your_maps_api_key_here
